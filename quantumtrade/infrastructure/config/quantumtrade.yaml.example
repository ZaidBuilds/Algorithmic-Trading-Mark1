---
# QuantumTrade YAML Configuration
# Copy this file to config/quantumtrade.yaml and customize

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────
database:
  POSTGRES_HOST: localhost
  POSTGRES_PORT: 5432
  POSTGRES_USER: quantum
  POSTGRES_PASSWORD: quantum
  POSTGRES_DB: quantumtrade
  DB_POOL_SIZE: 10

# ─────────────────────────────────────────────────────────────────────────────
# Redis / Event Bus Configuration
# ─────────────────────────────────────────────────────────────────────────────
redis:
  REDIS_HOST: localhost
  REDIS_PORT: 6379
  REDIS_DB: 0

event_bus:
  MESSAGE_BUS_URL: redis://localhost:6379/0
  EVENT_STREAM_MAX_LEN: 10000
  CONSUMER_GROUP: quantumtrade
  EVENT_RETENTION_MS: 604800000  # 7 days

# ─────────────────────────────────────────────────────────────────────────────
# Broker Configuration
# ─────────────────────────────────────────────────────────────────────────────
broker:
  BROKER_NAME: paper  # "paper", "alpaca", or "binance"
  PAPER_TRADING: true

  # Alpaca (uncomment when using)
  # ALPACA_API_KEY: "YOUR_KEY"
  # ALPACA_API_SECRET: "YOUR_SECRET"
  # ALPACA_PAPER: true

  # Binance (uncomment when using)
  # BINANCE_API_KEY: "YOUR_KEY"
  # BINANCE_API_SECRET: "YOUR_SECRET"
  # BINANCE_TESTNET: true

# ─────────────────────────────────────────────────────────────────────────────
# Strategy Configuration
# ─────────────────────────────────────────────────────────────────────────────
strategy:
  STRATEGY_NAME: "EMA Crossover"
  TIMEFRAME: "5m"
  INITIAL_CAPITAL: 100000.0
  DEFAULT_ORDER_SIZE: 1.0
  ML_MODEL_PATH: "models/"
  ML_RETRAIN_DAYS: 30
  OLLAMA_HOST: "http://localhost:11434"
  OLLAMA_MODEL: "qwen2.5-coder:1.5b"

# ─────────────────────────────────────────────────────────────────────────────
# Risk Management
# ─────────────────────────────────────────────────────────────────────────────
risk:
  MAX_POSITION_SIZE_PCT: 0.10      # 10% per position
  STOP_LOSS_PCT: 0.02              # 2% stop-loss
  TAKE_PROFIT_PCT: 0.04           # 4% take-profit
  MAX_DAILY_LOSS_PCT: 0.05        # 5% daily loss limit
  MAX_OPEN_POSITIONS: 10
  MIN_CASH_RESERVE_PCT: 0.20      # Keep 20% cash
  MAX_DAILY_TRADES: 50
  VAR_95_CONFIDENCE: 0.05

# ─────────────────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────────────────
notifications:
  TELEGRAM_BOT_TOKEN: null  # Set via env var: QT_TELEGRAM_BOT_TOKEN
  TELEGRAM_CHAT_ID: null
  DISCORD_WEBHOOK_URL: null
  EMAIL_SMTP_HOST: null
  EMAIL_SMTP_PORT: 587
  EMAIL_USER: null
  EMAIL_PASSWORD: null
  EMAIL_TO: null
  NOTIFICATION_LEVEL: "INFO"

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
logging:
  LOG_LEVEL: "INFO"
  LOG_FILE: "logs/trading_bot.log"
  JSON_LOGS: false
  LOG_ROTATION: "daily"

# ─────────────────────────────────────────────────────────────────────────────
# API Server (optional)
# ─────────────────────────────────────────────────────────────────────────────
api:
  API_ENABLED: false
  API_HOST: "0.0.0.0"
  API_PORT: 8000

# ─────────────────────────────────────────────────────────────────────────────
# Trading Engine
# ─────────────────────────────────────────────────────────────────────────────
SYMBOLS: ["AAPL", "GOOGL", "MSFT", "TSLA"]
TRADING_INTERVAL_SECONDS: 300  # 5 minutes
RESPECT_MARKET_HOURS: true
DATA_DIR: "data"
ENVIRONMENT: "development"
