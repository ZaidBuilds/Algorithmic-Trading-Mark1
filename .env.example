# ══════════════════════════════════════════════
# QuantumTrade — Configuration
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ─────────────────────────────────────────
# 🔧 Operating Mode
# ─────────────────────────────────────────
MODE=PAPER                        # BACKTEST | PAPER | LIVE

# ─────────────────────────────────────────
# 🏦 Broker (choose one)
# ─────────────────────────────────────────
BROKER_NAME=paper                 # paper | alpaca | binance

# Alpaca (US Stocks + Crypto)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true                 # true = paper trading, false = REAL MONEY

# Binance (Crypto)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true              # true = testnet, false = REAL MONEY

# ─────────────────────────────────────────
# 📈 Strategy
# ─────────────────────────────────────────
STRATEGY_NAME=EMA Crossover
# Available: EMA Crossover, SMA, RSI, MACD, Bollinger Bands,
#            VWAP, Breakout, Mean Reversion, Momentum, Scalping

# ─────────────────────────────────────────
# 💰 Trading Parameters
# ─────────────────────────────────────────
SYMBOLS=["AAPL","GOOG","MSFT"]
TIMEFRAME=1d                      # 1m | 5m | 15m | 1h | 1d
INITIAL_CAPITAL=100000.0

# ─────────────────────────────────────────
# 🛡️ Risk Management
# ─────────────────────────────────────────
MAX_POSITION_SIZE_PCT=0.10        # Max 10% per position
STOP_LOSS_PCT=0.02                # 2% stop-loss
TAKE_PROFIT_PCT=0.04              # 4% take-profit
MAX_DAILY_LOSS_PCT=0.05           # 5% daily loss limit
MAX_OPEN_POSITIONS=10             # Max simultaneous positions
MIN_CASH_RESERVE_PCT=0.20         # Keep 20% cash reserve

# ─────────────────────────────────────────
# ⏱️ Scheduler
# ─────────────────────────────────────────
TRADING_INTERVAL_SECONDS=300      # 5 min between ticks
RESPECT_MARKET_HOURS=true         # Only trade during market hours

# ─────────────────────────────────────────
# 🔔 Notifications (all optional)
# ─────────────────────────────────────────
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# ─────────────────────────────────────────
# 📊 Backtesting
# ─────────────────────────────────────────
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2023-12-31
COMMISSION_PCT=0.001              # 0.1% per trade

# ─────────────────────────────────────────
# 🤖 AI / ML
# ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
ML_MODEL_PATH=models/
ML_RETRAIN_DAYS=30

# ─────────────────────────────────────────
# 📁 Data & Logging
# ─────────────────────────────────────────
DATA_DIR=data
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# ─────────────────────────────────────────
# 📈 Distributed Tracing (OpenTelemetry)
# ─────────────────────────────────────────
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SAMPLING_RATIO=0.1          # 10% sampling rate (set to 1.0 for dev)
OTEL_SERVICE_NAME=quantumtrade
